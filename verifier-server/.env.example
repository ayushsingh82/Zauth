PORT=4000

# HashKey Chain Testnet (chain id 133)
HASHKEY_RPC_URL=https://testnet.hsk.xyz
HASHKEY_CHAIN_ID=133

# Live deployed Groth16 verifier. Deployed 2026-04-18 on HashKey testnet.
#   https://testnet-explorer.hsk.xyz/address/0xC40c974E6D50D201C93265a9D8423e30D0C551aE
VERIFIER_CONTRACT=0xC40c974E6D50D201C93265a9D8423e30D0C551aE
VERIFIER_MODE=groth16

# Optional — only needed if you intend to submit on-chain attestations from
# the verifier-server itself rather than the client.
#   https://testnet-explorer.hsk.xyz/address/0x0c9CfcfDfDA0317659DEB59d3409D059a0DCe5DB
ATTESTOR_CONTRACT=0x0c9CfcfDfDA0317659DEB59d3409D059a0DCe5DB

HASHKEY_PRIVATE_KEY=0x
HASHKEY_PUBLIC_ADDRESS=0x

JWT_SECRET=replace-with-a-strong-secret
CHALLENGE_EXPIRY_SECONDS=300
